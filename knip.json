{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "simple.ts",
    "folder.ts",
    "web.ts",
    "rating.ts",
    "src/taglib/index.ts",
    "src/msgpack/index.ts",
    "src/types/index.ts",
    "src/runtime/unified-loader/index.ts",
    "tests/**/*.test.ts",
    "tests/**/*.bench.ts",
    "tests/test-files/_gen/make-bwf-fixtures.ts",
    "scripts/**/*.{ts,mjs,js}"
  ],
  "project": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.{ts,mjs,js}"
  ],
  "ignore": [
    "build/**",
    "dist/**",
    "lib/**",
    "docs/**"
  ],
  "ignoreDependencies": [
    "@std/.*",
    "@msgpack/msgpack",
    "npm"
  ],
  "ignoreBinaries": [
    "publint",
    "vite"
  ]
}
